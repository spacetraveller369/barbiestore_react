<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Barbie Store - Панель Администратора</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 30px; background-color: #fff0f5; color: #333; }
        h1, h2 { color: #e0115f; text-shadow: 1px 1px 2px rgba(0,0,0,0.1); }
        .containers-wrapper { display: flex; gap: 30px; flex-wrap: wrap; margin-bottom: 40px; }
        .form-container { background: white; padding: 25px; border-radius: 12px; width: 450px; box-shadow: 0 4px 15px rgba(224, 17, 95, 0.15); border: 1px solid #ffb6c1; box-sizing: border-box; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-weight: bold; color: #d10056; }
        .form-group input, .form-group textarea { width: 100%; padding: 10px; box-sizing: border-box; border: 1px solid #ffb6c1; border-radius: 6px; }
        .form-group input:focus, .form-group textarea:focus { outline: none; border-color: #e0115f; box-shadow: 0 0 5px rgba(224, 17, 95, 0.3); }
        button { background: #e0115f; color: white; padding: 12px 20px; border: none; border-radius: 6px; cursor: pointer; font-size: 1em; font-weight: bold; width: 100%; transition: background 0.2s; }
        button:hover { background: #c20e50; }
        .products-grid { display: flex; gap: 25px; flex-wrap: wrap; }
        .product-card { background: white; border: 1px solid #ffb6c1; padding: 20px; border-radius: 12px; width: 240px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.05); display: flex; flex-direction: column; justify-content: space-between; }
        .product-card img { max-width: 100%; height: 200px; object-fit: cover; border-radius: 8px; margin-bottom: 15px; }
        .product-card h3 { margin: 10px 0; color: #444; font-size: 1.2em; }
        .product-card p { font-size: 0.9em; color: #666; margin-bottom: 15px; flex-grow: 1; }
        .price { color: #e0115f; font-weight: bold; font-size: 1.3em; margin-bottom: 10px; }
    </style>
</head>
<body>

    <h1>🎀 Бэкенд-панель Barbie Store 🎀</h1>
    
    <div class="containers-wrapper">
        <div class="form-container">
            <h2>Добавить новую куклу в БД</h2>
            <form id="barbieForm">
                <div class="form-group">
                    <label>Название модели куклы:</label>
                    <input type="text" id="name" required>
                </div>
                <div class="form-group">
                    <label>Цена ($):</label>
                    <input type="number" step="0.01" id="price" required>
                </div>
                <div class="form-group">
                    <label>Ссылка на изображение куклы:</label>
                    <input type="url" id="image_url" required>
                </div>
                <div class="form-group">
                    <label>Описание куклы:</label>
                    <textarea id="description" rows="3"></textarea>
                </div>
                <button type="submit">Добавить в каталог товаров</button>
            </form>
        </div>

        <div class="form-container" style="border-color: #1db954;">
            <h2 style="color: #1db954;">Управление городами</h2>
            <p style="font-size: 0.9em; color: #666; margin-bottom: 20px;">Эмуляция POST/GET запросов</p>
            <button type="button" onclick="addCities()" style="background-color: #1db954; margin-bottom: 15px;">Добавить города</button>
            <button type="button" onclick="getCities()" style="background-color: #1ed760; margin-bottom: 15px;">Получить список городов</button>
            <div id="cityResult" style="margin-top: 15px; font-weight: bold; text-align: left; background: #fff; padding: 10px; border-radius: 6px; border: 1px dashed #1db954; min-height: 40px;">Ожидание действий...</div>
        </div>
    </div>

    <h2>Текущие товары и объекты во внешней Базе Данных PostgreSQL:</h2>
    <div class="products-grid" id="productsGrid">
        <% if (products && products.length > 0) { %>
            <% products.forEach(function(product) { %>
                <div class="product-card">
                    <div>
                        <img src="<%= product.image_url %>" alt="<%= product.name %>">
                        <h3><%= product.name %></h3>
                        <p><%= product.description ? product.description : "Описание отсутствует." %></p>
                    </div>
                    <div class="price">$<%= product.price %></div>
                </div>
            <% }) %>
        <% } else { %>
            <p id="emptyMessage">В базе данных пока нет товаров.</p>
        <% } %>
    </div>

    <script>
        
        document.getElementById('barbieForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const productData = {
                name: document.getElementById('name').value,
                price: parseFloat(document.getElementById('price').value),
                image_url: document.getElementById('image_url').value,
                description: document.getElementById('description').value
            };

            try {
                const response = await fetch('/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(productData)
                });

                if (response.ok) {
                    const grid = document.getElementById('productsGrid');
                    const emptyMsg = document.getElementById('emptyMessage');
                    if (emptyMsg) emptyMsg.remove();

                    const newCard = document.createElement('div');
                    newCard.className = 'product-card';
                    newCard.innerHTML = `
                        <div>
                            <img src="${productData.image_url}" alt="${productData.name}">
                            <h3>${productData.name}</h3>
                            <p>${productData.description ? productData.description : "Описание отсутствует."}</p>
                        </div>
                        <div class="price">$${productData.price}</div>
                    `;
                    
                    grid.appendChild(newCard);
                    document.getElementById('barbieForm').reset();
                } else {
                    alert('Ошибка при добавлении товара на сервере');
                }
            } catch (error) {
                console.error('Ошибка сети:', error);
            }
        });

        const addCitiesUrl = '/dotnet/upload.php';
        const getCitiesUrl = '/dotnet/get_cities.php';
        const resultDiv = document.querySelector('#cityResult');
        const cities = ['Одесса', 'Харьков', 'Ужгород', 'Днепр', 'Черкассы'];

        async function addCities() {
            resultDiv.innerHTML = '<p style="color: #666;">Отправка...</p>';
            try {
                const response = await fetch(addCitiesUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(cities)
                });
                if (!response.ok) {
                    throw new Error(`Ошибка при добавлении: ${response.statusText}`);
                }
                const resData = await response.json();
                resultDiv.innerHTML = `<p style="color: #1db954;">${resData[0] || 'Города успешно добавлены'}</p>`;
                
                setTimeout(() => { window.location.reload(); }, 1500);
            } catch (error) {
                resultDiv.innerHTML = `<p style="color: red;">Возникла ошибка: ${error.message}</p>`;
            }
        }

        async function getCities() {
            resultDiv.innerHTML = '<p style="color: #666;">Загрузка...</p>';
            try {
                const response = await fetch(getCitiesUrl, {
                    method: 'GET',
                    headers: { 'Accept': 'application/json' }
                });
                if (!response.ok) {
                    throw new Error(`Ошибка при получении городов: ${response.statusText}`);
                }
                const citiesList = await response.json();
                if (citiesList && Array.isArray(citiesList)) {
                    resultDiv.innerHTML = `
                        <p style="color: #333; margin: 0 0 5px 0;">Список всех городов/объектов:</p>
                        <ul style="margin: 0; padding-left: 15px; color: #555; font-size: 0.95em;">
                            ${citiesList.map(c => `<li>${c}</li>`).join('')}
                        </ul>
                    `;
                } else {
                    resultDiv.innerHTML = '<p>Список пуст.</p>';
                }
            } catch (error) {
                resultDiv.innerHTML = `<p style="color: red;">Возникла ошибка: ${error.message}</p>`;
            }
        }
    </script>
</body>
</html>